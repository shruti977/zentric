// Prisma schema for Zentric – AI Growth Operating System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  tasks         Task[]
  goals         Goal[]
  studyTopics   StudyTopic[]
  practiceProgress StudyPracticeProgress[]
  notes         Note[]
  conversations Conversation[]
  careerProfile CareerProfile?
  jobApplications JobApplication[]
  settings      UserSettings?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("medium")
  deadline    DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String   @id @default(cuid())
  title     String
  progress  Int      @default(0)
  target    Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyTopic {
  id         String   @id @default(cuid())
  name       String
  category   String   @default("DSA")
  status     String   @default("not_started")
  notes      String?
  difficulty String   @default("medium")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceProgress StudyPracticeProgress[]
}

model StudyPracticeProgress {
  id           String     @id @default(cuid())
  questionId   String
  completedAt  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  studyTopicId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyTopic   StudyTopic @relation(fields: [studyTopicId], references: [id], onDelete: Cascade)

  @@unique([userId, studyTopicId, questionId])
  @@index([studyTopicId])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String?
  category  String   @default("second_brain")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String    @id @default(cuid())
  title        String    @default("New Conversation")
  systemPrompt String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model CareerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  dreamRole         String   @default("Your Dream Role")
  targetCompany     String   @default("Your Target Company")
  resumeText        String?
  skillsText        String?
  projectsText      String?
  experienceText    String?
  educationText     String?
  preferredKeywords String?
  jobDescriptionText String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id        String    @id @default(cuid())
  company   String
  role      String
  status    String    @default("wishlist")
  location  String?
  url       String?
  notes     String?
  appliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  theme             String  @default("dark")
  openaiApiKey      String?
  displayName       String?
  bio               String?
  leetcodeUsername  String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
